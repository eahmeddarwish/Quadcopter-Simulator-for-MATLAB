#VRML V2.0 utf8
# AprilNav — generic Virtual Reality world for the quadcopter VR Sink block.
#
# This file provides a plain, neutral floor so the model runs out of the
# box for ANY environment without requiring building photos or textures. Everything below other than the
# floor/background is required by the Simulink VR Sink block's field
# bindings (quadcopter, blade1-4, LandingMarker_Waypoint, LineIndexedList,
# LineCoordinates) -- do not rename these DEF nodes.
#
# Detailed/photorealistic 3D room reconstruction is intentionally out of
# scope for AprilNav (see docs/ARCHITECTURE.md). If you want a richly
# textured VR world for your own space, author your own .wrl and point the
# "vr_world_file" field in your environment config at it.

Background {
  skyColor 0.10 0.10 0.13
}

DEF Floor Transform {
  translation 30 -0.05 30
  children Shape {
    appearance Appearance {
      material Material {
        diffuseColor 0.55 0.55 0.58
        ambientIntensity 0.6
      }
    }
    geometry Box {
      size 120 0.1 120
    }
  }
}

DEF quadcopter Transform {
  translation 57 0.43 95
  rotation 0 1 0 0
  children [
    DEF body Transform {
      rotation 0 1 0 0.785
      children Inline {
        url "body.wrl"
      }
    }
    DEF blade1 Transform {
      translation -0.285 0.095 -0.278
      children Inline {
        url "propeller.wrl"
      }
    }
    DEF blade2 Transform {
      translation -0.3 0.095 0.3
      children Inline {
        url "propeller.wrl"
      }
    }
    DEF blade3 Transform {
      translation 0.285 0.095 -0.278
      children Inline {
        url "propeller.wrl"
      }
    }
    DEF blade4 Transform {
      translation 0.3 0.095 0.3
      children Inline {
        url "propeller.wrl"
      }
    }
    DEF OnQuad Viewpoint {
      description "Chase"
      position -2 0.25 0
      orientation 0 1 0 -1.57
    }
    DEF Isometric Viewpoint {
      description "Isometric"
      position 2 1 2
      orientation -0.46727 0.8587 0.21047 0.8
    }
    DEF TopView Viewpoint {
      description "TopView"
      position 0 2 0
      orientation 1 0 0 -1.57
    }
  ]
}
DEF LandingMarker Transform {
  translation 57 0 95
  children Shape {
    appearance Appearance {
      material Material {
        diffuseColor 1 0 0
      }
    }
    geometry Box {
      size 0.5 0.05 0.5
    }
  }
}
DEF LandingMarker_Waypoint Transform {
  translation 57 0 95
  children Shape {
    appearance Appearance {
      material Material {
        diffuseColor 0 0 1
      }
    }
    geometry Box {
      size 0.1 0.049 0.1
    }
  }
}
DEF LineTransform Transform {
  children DEF LineShape Shape {
    appearance DEF LineAppearance Appearance {
      material Material {
        diffuseColor 1 0 0.2
      }
    }
    geometry DEF LineIndexedList IndexedLineSet {
      coord DEF LineCoordinates Coordinate {
      }
      color Color {
        color 1 0 0.4
      }
    }
  }
}
